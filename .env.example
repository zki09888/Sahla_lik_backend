# ═══════════════════════════════════════════════════════════════════════════════
# SAHLA-LIK Backend - Environment Variables Template
# Copy this file to .env and update with your configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# Database Configuration
# ───────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=sahlalik_db
DATABASE_URL=mysql://root:your_mysql_password_here@localhost:3306/sahlalik_db

# ───────────────────────────────────────────────────────────────────────────────
# JWT Authentication
# IMPORTANT: Change JWT_SECRET in production! Generate a random 32+ char string.
# ───────────────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_in_production_to_a_random_string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ───────────────────────────────────────────────────────────────────────────────
# Server Configuration
# ───────────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ───────────────────────────────────────────────────────────────────────────────
# CORS Origins (comma-separated)
# Add your frontend URLs here
# ───────────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000,http://10.0.2.2:3001,http://10.0.2.2:3000

# ───────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ───────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
